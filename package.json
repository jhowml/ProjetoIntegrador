{
  "name": "marmitas-api",
  "version": "1.0.0",
  "description": "API REST para controle de vendas de marmitas",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "db:generate": "tsx scripts/prisma-env.ts generate",
    "db:migrate": "tsx scripts/prisma-env.ts migrate dev",
    "db:migrate:deploy": "tsx scripts/prisma-env.ts migrate deploy",
    "db:studio": "tsx scripts/prisma-env.ts studio",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.13.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.1.0",
    "pino-http": "^10.1.0",
    "pino-pretty": "^11.0.0",
    "zod": "^3.23.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.2",
    "@vitest/coverage-v8": "^1.6.0",
    "prisma": "^5.13.0",
    "supertest": "^7.0.0",
    "tsx": "^4.15.1",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
